{
  "name": "pandda-inspect-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "copy:assets": "copyfiles -u 3 \"node_modules/moorhen/public/**/*\" public/ && copyfiles -u 4 \"node_modules/@rdkit/rdkit/dist/RDKit_minimal.*\" public/",
    "dev": "npm run copy:assets && vite",
    "build": "npm run copy:assets && tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "@reduxjs/toolkit": "^2.8.2",
    "@rdkit/rdkit": "^2024.3.5-1.0.0",
    "moorhen": "file:moorhen-0.23.1-alpha.0.tgz",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "copyfiles": "^2.4.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
