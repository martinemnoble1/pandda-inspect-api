# pandda-inspect-api — environment configuration.
# Copy to `.env` and edit. `.env` is git-ignored: it holds YOUR machine's paths.
# See docs/SETUP.md and DESIGN-artifacts-and-jobs.md §5.7 for the full rationale.

# --- Paths (Developer + Tester) -------------------------------------------
# Where ingested PanDDA project trees live, so the API can stream artifacts.
# Defaults to <repo>/data if unset.
PANDDA_DATA_ROOT=

# SQLite database file. Defaults to <repo>/db.sqlite3 if unset. In a packaged
# (read-only) app bundle this MUST point at a user-writable location.
PANDDA_DB_PATH=

# Where job working dirs are written. Defaults to PANDDA_DATA_ROOT if unset.
PANDDA_JOBS_ROOT=

# --- Refinement activation (Tester only) ----------------------------------
# Leave UNSET for a developer / CCP4-free setup — refinement dispatch is then
# gated in the UI and everything else works. To enable refinement, point
# CCP4_SETUP_SH at YOUR CCP4 install: the runner drives `servalcat` from stock
# CCP4 (DESIGN §5.8), so no conda env is needed for the default engine.
#
# Example (yours will differ):
#   CCP4_SETUP_SH=/Applications/ccp4-9/bin/ccp4.setup-sh
CCP4_SETUP_SH=

# Optional: only needed if REFINE_TOOL points at a conda-env-only tool.
# servalcat (the default) does NOT need these. The runner sources CCP4 FIRST,
# then the conda env (order matters — CCP4 ships an older PanDDA1 giant.refine
# that can otherwise shadow a conda tool; see docs/SETUP.md §B).
CONDA_SH=
PANDDA2_CONDA_ENV=

# Refinement engine invoked AFTER activation. Default servalcat; refmac5 is a
# supported fallback. Tests override this with a stand-in command.
# REFINE_TOOL=servalcat
