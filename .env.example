# pandda-inspect-api — environment configuration.
# Copy to `.env` and edit. `.env` is git-ignored: it holds YOUR machine's paths.
# See docs/SETUP.md and DESIGN-artifacts-and-jobs.md §5.7 for the full rationale.

# --- Paths (Developer + Tester) -------------------------------------------
# Where ingested PanDDA project trees live, so the API can stream artifacts.
# Defaults to <repo>/data if unset.
PANDDA_DATA_ROOT=

# SQLite database file. Defaults to <repo>/db.sqlite3 if unset. In a packaged
# (read-only) app bundle this MUST point at a user-writable location.
PANDDA_DB_PATH=

# Where job working dirs are written. Defaults to PANDDA_DATA_ROOT if unset.
PANDDA_JOBS_ROOT=

# --- Refinement activation (Tester only) ----------------------------------
# Leave these UNSET for a developer / CCP4-free setup — refinement dispatch is
# then gated in the UI and everything else works. To enable refinement, point
# at YOUR CCP4 + PanDDA2-conda installs. ORDER MATTERS: CCP4 is sourced first,
# then the conda env, so the PanDDA2 giant.quick_refine wins over CCP4's
# PanDDA1 one (see docs/SETUP.md §B.1 footgun).
#
# Example values (yours will differ):
#   CCP4_SETUP_SH=/Applications/ccp4-9/bin/ccp4.setup-sh
#   CONDA_SH=/Users/you/miniconda3/etc/profile.d/conda.sh
#   PANDDA2_CONDA_ENV=pandda2
CCP4_SETUP_SH=
CONDA_SH=
PANDDA2_CONDA_ENV=

# Tool name invoked AFTER activation (override only for testing with a stand-in
# command; the real default is the PanDDA2 giant.quick_refine).
# REFINE_TOOL=giant.quick_refine
